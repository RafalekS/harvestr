{
  "_comment": "Site URL patterns for username-based enumeration. {u} = username. yt-dlp's extractor is tried against each pattern; first hit wins. Sites are listed most-reliable first within their tier. Disable any site by removing it from the 'enabled' list in config.json.",
  "sites": {
    "youtube": {
      "category": "mainstream",
      "patterns": [
        "https://www.youtube.com/@{u}/videos",
        "https://www.youtube.com/@{u}/streams",
        "https://www.youtube.com/c/{u}/videos",
        "https://www.youtube.com/user/{u}/videos"
      ],
      "yt_dlp_extractor": "youtube",
      "supports_flat": true,
      "notes": "YouTube handle format preferred (@user). Shorts/streams are separate tabs."
    },
    "twitch": {
      "category": "mainstream",
      "patterns": [
        "https://www.twitch.tv/{u}/videos",
        "https://www.twitch.tv/{u}/clips"
      ],
      "yt_dlp_extractor": "twitch",
      "supports_flat": true,
      "notes": "VODs and clips only; live streams handled separately."
    },
    "vimeo": {
      "category": "mainstream",
      "patterns": [
        "https://vimeo.com/{u}",
        "https://vimeo.com/user/{u}"
      ],
      "yt_dlp_extractor": "vimeo",
      "supports_flat": true,
      "notes": "Some users have numeric IDs instead of usernames."
    },
    "rumble": {
      "category": "mainstream",
      "patterns": [
        "https://rumble.com/c/{u}",
        "https://rumble.com/user/{u}"
      ],
      "yt_dlp_extractor": "rumble",
      "supports_flat": true
    },
    "dailymotion": {
      "category": "mainstream",
      "patterns": [
        "https://www.dailymotion.com/{u}"
      ],
      "yt_dlp_extractor": "dailymotion",
      "supports_flat": true
    },
    "bitchute": {
      "category": "mainstream",
      "patterns": [
        "https://www.bitchute.com/channel/{u}/"
      ],
      "yt_dlp_extractor": "bitchute",
      "supports_flat": true
    },
    "odysee": {
      "category": "mainstream",
      "patterns": [
        "https://odysee.com/@{u}",
        "https://odysee.com/@{u}:c"
      ],
      "yt_dlp_extractor": "odysee",
      "supports_flat": true
    },
    "soundcloud": {
      "category": "mainstream",
      "patterns": [
        "https://soundcloud.com/{u}/tracks"
      ],
      "yt_dlp_extractor": "soundcloud",
      "supports_flat": true,
      "notes": "/tracks endpoint only (user's uploads). The bare /{u} URL also includes reposts of other users' tracks, which cross-contaminate the performer folder."
    },
    "archive_org": {
      "category": "archive",
      "patterns": [
        "https://archive.org/details/@{u}"
      ],
      "yt_dlp_extractor": "archiveorg",
      "supports_flat": true
    },
    "kick": {
      "category": "mainstream",
      "patterns": [
        "https://kick.com/{u}/videos",
        "https://kick.com/{u}/clips"
      ],
      "yt_dlp_extractor": "kick",
      "supports_flat": true
    },
    "pornhub": {
      "category": "adult",
      "patterns": [
        "https://www.pornhub.com/model/{u}",
        "https://www.pornhub.com/pornstar/{u}",
        "https://www.pornhub.com/users/{u}",
        "https://www.pornhub.com/channels/{u}"
      ],
      "yt_dlp_extractor": "pornhub",
      "supports_flat": true,
      "notes": "Try model/pornstar/users/channels in order; first non-empty wins."
